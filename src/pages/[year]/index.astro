---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TrackPlayer from "../../components/TrackPlayer.tsx";

export async function getStaticPaths() {
  const allSets = await getCollection("questions");
  return allSets.map((set) => ({
    params: { year: String(set.data.year) },
    props: { set },
  }));
}

const { set } = Astro.props;
const { year, questions } = set.data;

const tracks = questions.map((q) => ({
  number: q.number,
  title: `Passage ${q.number}`,
  src: q.audioPath,
  transcript: q.passage,
  instruction: q.instruction,
}));
---

<BaseLayout title={`${year}年度 リスニング`}>
  <!-- 戻るボタン（固定・左上） -->
  <button
    id="back-btn"
    aria-label="ホームに戻る"
    class="fixed top-4 left-4 z-50 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 active:bg-white/30 text-white transition-colors"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-5 h-5">
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </button>

  <div id="page-content" class="space-y-8" style="transition: transform 0.4s ease-in, opacity 0.4s ease-in;">
    <!-- トラックプレイヤー -->
    {tracks.length > 0 ? (
      <TrackPlayer client:load tracks={tracks} />
    ) : (
      <div class="bg-white/10 rounded-xl p-10 text-center">
        <p class="text-white/50 text-sm">この年度の音声データは現在準備中です。</p>
      </div>
    )}
  </div>
</BaseLayout>

<script>
  document.getElementById("back-btn")?.addEventListener("click", () => {
    const content = document.getElementById("page-content");
    if (content) {
      content.style.transform = "translateY(100vh)";
      content.style.opacity = "0";
    }
    setTimeout(() => {
      window.location.href = "/";
    }, 380);
  });
</script>
